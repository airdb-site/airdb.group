---
import "../styles/global.css";
import { company, footerGroups, navigation } from "../config/site";

interface Props {
  title: string;
  description?: string;
  activePath?: string;
}

const {
  title,
  description = "airdb Group builds AI infrastructure and enterprise delivery systems.",
  activePath = "/"
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=Source+Serif+4:wght@600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="site-header">
      <div class="shell nav-shell" data-mobile-nav-root>
        <div class="nav-topline">
          <a class="brand" href="/">
            <span class="brand-mark">{company.shortName}</span>
            <span class="brand-group">Group</span>
          </a>
          <button
            class="nav-toggle"
            type="button"
            aria-expanded="false"
            aria-controls="primary-nav"
            aria-label="Toggle navigation"
            data-mobile-nav-toggle
          >
            <span></span>
            <span></span>
          </button>
        </div>
        <nav class="site-nav" id="primary-nav" aria-label="Primary">
          {
            navigation.map((item) => (
              <a
                href={item.href}
                class:list={[
                  "nav-link",
                  activePath === item.href && "is-active"
                ]}
              >
                {item.label}
              </a>
            ))
          }
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="shell footer-grid">
        <div class="footer-brand">
          <p class="eyebrow">AIRDB Group</p>
          <h2>Corporate presence with technical depth.</h2>
          <p class="footer-copy">
            Designed for enterprise customers, partners, technical candidates,
            and diligence reviewers.
          </p>
          <a class="footer-mail" href={`mailto:${company.email}`}>{company.email}</a>
        </div>
        <div class="footer-columns">
          {
            footerGroups.map((group) => (
              <section>
                <h3>{group.title}</h3>
                <div class="footer-links">
                  {group.links.map((item) => <a href={item.href}>{item.label}</a>)}
                </div>
              </section>
            ))
          }
        </div>
      </div>
    </footer>
    <script is:inline>
      const navRoot = document.querySelector("[data-mobile-nav-root]");
      const navToggle = document.querySelector("[data-mobile-nav-toggle]");

      if (navRoot instanceof HTMLElement && navToggle instanceof HTMLButtonElement) {
        const syncNav = () => {
          if (window.innerWidth > 760) {
            navRoot.dataset.mobileNavOpen = "true";
            navToggle.setAttribute("aria-expanded", "false");
            return;
          }

          if (!navRoot.dataset.mobileNavOpen) {
            navRoot.dataset.mobileNavOpen = "false";
          }
        };

        syncNav();

        navToggle.addEventListener("click", () => {
          const isOpen = navRoot.dataset.mobileNavOpen === "true";
          navRoot.dataset.mobileNavOpen = isOpen ? "false" : "true";
          navToggle.setAttribute("aria-expanded", String(!isOpen));
        });

        window.addEventListener("resize", syncNav);
      }
    </script>
  </body>
</html>
